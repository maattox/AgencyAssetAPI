{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:YOUR-SERVER.database.windows.net,1433;Initial Catalog=AgencyAssetDB;User ID=YOUR-SQL-ADMIN;Password=YOUR-PASSWORD;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "SpecialValues": {
    "MaxDaysSinceLastAudit": 90, // Maximum number of days since the last audit before an asset is considered overdue for audit
    "StorageAccountName": "myagencyassetstore"
  },
  "Authorization": {
    "ApiKey": "your-local-dev-api-key"
  },
}
